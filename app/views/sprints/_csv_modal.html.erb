<div class="modal fade" id="exportToCSV" tabindex="-1" role="dialog" aria-labelledby="exportToCSVLabel" aria-hidden="true">
  <div class="modal-dialog" role="document">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="exportToCSVLabel">Export to CSV</h5>
        <button type="button" class="close" data-dismiss="modal" aria-label="Close">
          <span aria-hidden="true">&times;</span>
        </button>
      </div>
      <div class="modal-body text-center">
        <%= link_to 'Generate CSV for current Sprint', '#', class: 'btn btn-lg btn-block btn-primary', data: { behavior: 'generateCSV' } %>
        <span style="display: none" data-behavior="generateCSVMessage">Please wait whilst we generate your CSV</span>
        <%= link_to 'Download CSV for current Sprint', '#', class: 'btn btn-lg btn-block btn-success', style: "display: none", data: { behavior: 'downloadCSV' } %>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-dismiss="modal">Close</button>
      </div>
    </div>
  </div>
</div>
<%= form_for @sprint do |f| %>
  <div class="row mt-4">
    <div class="col-sm-10">
      <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
          <li class="breadcrumb-item"><%= link_to "Home", root_path %></li>
          <li class="breadcrumb-item"><%= link_to "Sprints", sprints_path %></li>
          <li class="breadcrumb-item active" aria-current="page">New Sprint</li>
        </ol>
      </nav>
    </div>
    <div class="col-sm-2">
      <%= f.submit class: 'btn btn-success btn-block btn-lg' %>
    </div>
  </div>

  <%= render 'shared/errors', object: @sprint %>
  <div class="form-group mt-4">
    <%= f.label :name, 'Goal' %>
    <%= f.text_field :name, required: true, class: "form-control", placeholder: 'What is the goal of the sprint?' %>
  </div>
  <div class="form-group">
    <%= f.label :team %>
    <%= f.collection_select(:team_id, Team.all, :id, :name, {prompt: true, required: true}, class: "form-control") %>
  </div>
  <div class="form-group">
    <%= f.label :start_date %>
    <%= f.text_field :start_date, required: true, class: "form-control", type: :date %>
  </div>
  <div class="form-group">
    <%= f.label :end_date %>
    <%= f.text_field :end_date, required: true, class: "form-control", type: :date %>
  </div>

<% end %>

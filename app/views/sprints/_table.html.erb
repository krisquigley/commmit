<div class="table-responsive mt-4">
  <table class="table table-hover">
    <thead class="thead-light">
      <tr>
        <th>Goal</th>
        <th>Team</th>
        <th>Start Date</th>
        <th>End Date</th>
        <th>Effort Considered</th>
        <th>Current Velocity</th>
        <th>Status</th>
      </tr>
    </thead>
    <tbody>
      <% object.each do |sprint| %>
        <tr>
          <td><%= link_to sprint.name, sprint_path(sprint) %></td>
          <td><%= link_to sprint.team.name, team_path(sprint.team) %></td>
          <td><%= sprint.start_date.to_date.to_formatted_s(:long)  %></td>
          <td><%= sprint.end_date.to_date.to_formatted_s(:long)  %></td>
          <td><%= sprint.total_estimated_effort %></td>
          <td><%= sprint.velocity %></td>
          <td>
            <% if sprint.in_progress? %> 
              <b><%= sprint.status %></b>
            <% else %>
              <%= sprint.status %>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

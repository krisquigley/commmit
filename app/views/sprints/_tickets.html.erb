<div class="table-responsive">
  <table class="table table-hover">
    <thead class="thead-light">
      <tr>
        <th>#</th>
        <th>Title</th>
        <th width="10%">Estimated Effort</th>
        <th>Date Closed</th>
        <th>Assigned to</th>
        <th width="40%">Notes</th>
      </tr>
    </thead>
    <tbody>
    <% object.each do |ticket| %>
      <tr>
        <td><%= ticket.number %></td>
        <td><%= link_to ticket.title, ticket.url %></td>
        <td><%= text_field_tag :estimated_ticket_override, ticket.estimated_effort, {class: 'form-control', type: :number, step: '0.5', data: {behavior: 'updateEstimatedEffort', issueId: ticket.issue_id, sprintId: @sprint.id} } %></td>
        <td><%= ticket.closed_at_formatted %></td>
        <td><%= !ticket.users.empty? ? render(partial: 'users/link', collection: ticket.users, spacer_template: 'shared/comma') : "Unassigned" %></td>
        <td><%= text_area_tag :notes, ticket.notes, {class: 'form-control', data: {behavior: 'updateNote', issueId: ticket.issue_id, sprintId: @sprint.id}} %>
      </tr>
    <% end %>
    </tbody>
  </table>
</div>
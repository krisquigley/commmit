<%= form_for [@team, @sprint] do |f| %>
  <div class="row mt-4 mb-4">
    <div class="col-sm-10">
      <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
          <li class="breadcrumb-item"><%= link_to "Teams", root_path %></li>
          <li class="breadcrumb-item"><%= link_to @team.name, team_path(@team) %></li>
          <li class="breadcrumb-item active" aria-current="page">New Sprint</li>
        </ol>
      </nav>
    </div>
    <div class="col-sm-2">
      <%= f.submit class: 'btn btn-success btn-block btn-lg' %>
    </div>
  </div>
  <%= render "form", f: f %>
<% end %>

<div class="row mt-4">
  <div class="col-12">
    <nav aria-label="breadcrumb">
      <ol class="breadcrumb">
        <li class="breadcrumb-item"><%= link_to "Home", root_path %></li>
        <li class="breadcrumb-item"><%= link_to @sprint.team.name, team_path(@sprint.team) %></li>
        <li class="breadcrumb-item"><%= link_to @sprint.name, sprint_path(@sprint) %></li>
        <li class="breadcrumb-item active" aria-current="page">Manage</li>
      </ol>
    </nav>
  </div>
</div>

<div class="tab">
  <button class="tablinks active" data-behavior="openTab">Tickets</button>
  <button class="tablinks" data-behavior="openTab">Settings</button>
</div>

<% if @sprint.initial_ticket_ids.empty? %>
  <div class="card mt-4">
    <h5 class="card-header">Start Sprint?</h5>
    <div class="card-body">
      <%= form_for @sprint do |f| %>
        <div class="form-group">
          <%= f.label :finish_by, 'Finish Sprint early by?' %>
          <%= f.text_field :finish_by, class: "form-control", type: :date, value: @sprint.end_date&.strftime('%Y-%m-%d') || Date.today + 4.days %>
        </div>
        <%= f.submit 'Lock & Load', class: "btn btn-success", data: { confirm: 'Are you sure? You will not be able to change your initial sprint afterwards' } %> 
      <% end %>
    </div>
  </div>
<% end %>

<!-- Tab content -->
<div data-behavior="Tickets" class="tabcontent active">

  <%= hidden_field_tag :sprint_id, @sprint.id, data: { behavior: 'sprintId' } %>

  <div class="card mb-4">
    <h5 class="card-header">Assigned Tickets</h5>
    <div class="card-body">
      <div class="form-group">
        <div class="table-responsive">
          <table class="table table-sm">
            <thead class="thead-light">
              <th></th>
              <th>#</th>
              <th>Title</th>
              <th>Repository</th>
              <th>Options</th>
            </thead>
            <tbody data-behavior="assignedTickets" data-sprint-id="<%= @sprint.id %>">
            <% @sprint_tickets.each do |ticket| %>
              <% if @sprint.initial_ticket_ids.include?(ticket.id) %>
                <tr style="background-color: lightgrey" data-id="<%= ticket.id %>" data-issue-id="<%= ticket.issue_id %>">
                  <td>
                    &#8230;
                  </td>
                  <td>
                    <%= ticket.number %>
                  </td>
                  <td>
                    <%= link_to ticket.title, ticket.url %>
                  </td>
                  <td>
                    <%= hidden_field_tag :estimated_effort, ticket.estimated_effort, data: { behavior: 'estimatedEffort' } %>
                    <%= ticket.repository_name %>
                  </td>
                  <td width="5%">
                    <button class="btn btn-danger btn-sm btn-block" data-behavior="removeTicket" data-id="<%= ticket.id %>" disabled>Remove</button>
                  </td>
                </tr>
              <% else %>
                <tr data-id="<%= ticket.id %>" data-issue-id="<%= ticket.issue_id %>">
                  <td data-behavior="draggable" style="cursor: move;">
                    &#8230;
                  </td>
                  <td>
                    <%= ticket.number %>
                  </td>
                  <td>
                    <%= link_to ticket.title, ticket.url %>
                  </td>
                  <td>
                    <%= hidden_field_tag :estimated_effort, ticket.estimated_effort, data: { behavior: 'estimatedEffort' } %>
                    <%= ticket.repository_name %>
                  </td>
                  <td width="5%">
                    <button class="btn btn-danger btn-sm btn-block" data-behavior="removeTicket" data-id="<%= ticket.id %>">Remove</button>
                  </td>
                </tr>
              <% end %>
            <% end %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>

  <div class="card mb-4">
    <h5 class="card-header"><a id="available_tickets"></a>Available Tickets</h5>
    <div class="card-body">
      <div class="row">
        <div class="col-md-12">
          <h6 class="mb-4">Yesterday's Weather <span class="badge badge-secondary" data-toggle="tooltip" data-placement="top" title="Average velocity for the past 3 sprints"><%= @yesterdays_weather.floor %></span></h6>
          <h6 class="mb-4">Largest ticket size for sprint <span class="badge badge-secondary" data-toggle="tooltip" data-placement="top" title="Average velocity per person per day over the last three sprints for half a sprint"><%= average_velocity_per_person_per_day_half_sprint(@sprint, @recent_velocity_per_person_per_day) %></span></h6>
          <h6 class="mb-4">Effort Accounted for <span class="badge badge-secondary" data-behavior="effortAccountedFor" /></h6>
        </div>
      </div>
      <%= form_tag manage_sprint_path(@sprint, anchor: :available_tickets), method: :get do |f| %>
        <div class="form-row">
          <div class="col-md-7">
            <%= text_field_tag :search, params[:search], class: "form-control", placeholder: "Search" %>
          </div>
          <div class="col-md-4 mb-4">
            <%= select_tag :repository_name, options_from_collection_for_select(Ticket.all.select(:repository_name).distinct, :repository_name, :repository_name, params[:repository_name]), prompt: 'Filter by Repository', class: "form-control" %>
          </div>
          <div class="col-md-1">
            <%= submit_tag 'Filter', class: 'btn btn-success btn-block' %>
          </div>
        </div>
      <% end %>
      <div class="table-responsive">
        <table class="table table-sm mt-4">
          <thead class="thead-light">
            <th>#</th>
            <th>Title</th>
            <th>Repository</th>
            <th>Options</th>
          </thead>
          <tbody data-behavior="availableTickets">
          <% @tickets.each do |ticket| %>
            <tr>
              <td>
                <%= ticket.number %>
              </td>
              <td>
                <%= link_to ticket.title, ticket.url %>
              </td>
              <td>
                <%= ticket.repository_name %>
              </td>
              <td>
                <button class="btn btn-success btn-sm btn-block" data-behavior="addTicket" data-ticket-id="<%= ticket.issue_id %>">Add</button>
              </td>
            </tr>
          <% end %>
          </tbody>
        </table>
        <%= paginate @tickets, theme: 'twitter-bootstrap-4' %>
      </div>
    </div>
  </div>
</div>

<div data-behavior="Settings" class="tabcontent">
  <%= form_for @sprint do |f| %>
    <%= render 'form', f: f %>
    <div class="form-group">
      <%= f.label :days_off %>
      <%= f.text_field :days_off, class: "form-control" %>
    </div>
    <%= f.submit 'Update Sprint', class: "btn btn-success" %> 
  <% end %>
</div>

<%= javascript_pack_tag 'sprints' %>

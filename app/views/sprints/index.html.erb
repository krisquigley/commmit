<h1>Sprints</h1>
<%= link_to 'New Sprint', new_sprint_path, class: 'btn btn-success' %>
<table class="table table-hover">
  <thead>
    <tr>
      <th>Name</th>
      <th>Team</th>
      <th>Start Date</th>
      <th>End Date</th>
      <th>Available Effort</th>
      <th>Effort Used</th>
      <th>Effort Remaining</th>
    </tr>
  </thead>
  <tbody>
    <% @sprints.each do |sprint| %>
      <tr>
        <td><%= link_to sprint.name, sprint_path(sprint) %></td>
        <td><%= sprint.team.name %></td>
        <td><%= sprint.start_date %></td>
        <td><%= sprint.end_date %></td>
        <td><%= sprint.available_effort %></td>
        <td><%=  %></td>
        <td><%=  %></td>
      </tr>
    <% end %>
  </tbody>
</table>


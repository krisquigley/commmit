<% content_for :nav_header do %>
  Stories
<% end %> 

<div class="grid-content">
  <% if @stories.empty? %>
    <p class="text-center text-secondary mt-2">You haven't created any stories yet</p>
  <% end %>
  <div class="card-deck">
    <% @stories.each do |story| %>
      <div class="card">
        <div class="card-body">
          <h5>
            <b>
              <%= link_to "I want #{story.goal}#{story.reason.present? ? ',' : ''}", edit_story_path(story) %>
            </b>
          </h5>
          <% if story.reason.present? %><h6>so that <%= story.reason %>.</h6><% end %>
        </div>
        <div class="card-footer">
          <%= render 'shared/notes_icon' if story.notes.present? %>
          <small><i><%= story.created_at.strftime("%a, %B %d") %></i></small>
        </div>
      </div>
    <% end %>
  </div>
</div>

<%= render "shared/actions", actions: [{ label: 'New Story', path: new_story_path }] %>
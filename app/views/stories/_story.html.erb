<div class="card" data-controller="navigate" data-action="click->navigate#navigate" data-container="story">
  <div class="card-body card__flex">
    <div class="w-100">
      <h5 class="card--goal">
        <%= link_to "#{t('stories.form.goal.label')} #{story.goal}#{story.reason.present? ? ',' : ''}", 
                      edit_story_path(story), data: { navigate_target: :link } %>
      </h5>
      <% if story.reason.present? %>
        <h6 class="card--reason">
          <%= t('stories.form.reason.label') %> <%= story.reason %>.
        </h6>
      <% end %>
      <div class="mt-1">
        <%= render partial: 'values/value', collection: story.values.filter{|v| v.discarded_at.nil? } %>
      </div>
    </div>
    <%= button_to story_path(story), method: :delete, 
                                    class: 'link-button discard-link', 
                                    data: { 
                                      action: "click->navigate#stopPropagation" 
                                    },
                                    name: 'archive_story' do %>
      <%= render 'shared/icons/close_icon', classes: '' %> 
    <% end %>
  </div>
  <div class="card-footer">
    <div class="card-footer__left">
      <%= render 'shared/icons/notes_icon', classes: 'mr-1 card-footer__icon' if story.notes.present? %>
      <%= render 'shared/icons/repeat_icon', classes: 'mr-1 card-footer__icon' if story.repeatable? %>
      <%= render 'shared/icons/cog_icon', classes: 'mr-1 card-footer__icon' if story.automatic? %>
    </div>
    <div class="card-footer__right">
      <small><i><%= completed_or_added(story) %></i></small>
    </div>
  </div>
</div>
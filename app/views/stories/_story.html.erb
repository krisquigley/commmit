<%= turbo_frame_tag dom_id(story) do %>
  <div class="card" data-controller="navigate" data-action="click->navigate#navigate" data-container="story">
    <div class="card-body card__flex">
      <div class="w-100">
        <h5 class="card--goal">
          <%= link_to "#{t('stories.form.goal.label')} #{story.goal}#{story.reason.present? ? ',' : ''}", 
                        edit_story_path(story), data: { navigate_target: :link } %>
        </h5>
        <% if story.reason.present? %>
          <h6 class="card--reason">
            <%= t('stories.form.reason.label') %> <%= story.reason %>.
          </h6>
        <% end %>
        <div class="mt-1">
          <%= render partial: 'values/value', collection: story.values.filter{ |v| v.discarded_at.nil? } %>
        </div>
      </div>
      <%= button_to story_path(story),  method: :delete, 
                                        onclick: 'return confirm("Archive this Goal?")',
                                        class: 'link-button discard-link u-default-touch-area', 
                                        data: { 
                                          action: "click->navigate#stopPropagation" 
                                        },
                                        name: 'archive_story' do %>
        <%= image_tag '/images/icons/close_icon.svg' %> 
      <% end %>
    </div>
    <div class="card-footer">
      <div class="card-footer__left">
        <%= image_tag '/images/icons/notes_icon.svg', class: 'mr-1 card-footer__icon.svg' if story.notes.present? %>
        <%= image_tag '/images/icons/repeat_icon.svg', data: { test_id: 'repeat_icon' }, class: 'mr-1 card-footer__icon.svg' if story.repeatable? %>
        <%= image_tag '/images/icons/cog_icon.svg', data: { test_id: 'automatically_add' }, class: 'mr-1 card-footer__icon.svg' if story.automatic? %>
      </div>
      <div class="card-footer__right">
        <%= render 'shared/story_status', story: story %>
      </div>
    </div>
  </div>
<% end %>
<%= render 'shared/errors', object: story %>

<%= form_with model: story, html: { class: 'flex-form' } do |f| %>
  <div class="form-content" data-controller="stories">
    <%= render 'fields', f: f, story: story %>
  </div>
  
  <div class="form-group form-actions">
    <%= f.submit t('stories.form.create'), class: "btn btn-lg btn-success btn-block" %>
    <button type="button" class="btn btn-lg btn-secondary btn-block" data-dismiss="modal"><%= t('stories.form.cancel') %></button>
  </div>
<% end %>
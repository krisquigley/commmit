<div class="modal fade" id="chooseGoalModal" tabindex="-1" aria-labelledby="chooseGoalModalLabel" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content" data-controller="swipe-between-tabs">
    
      <%= render 'planned_stories/add_stories/modal_header' %>

      <div class="modal-body">
        <div class="tab-content modal-tab-content" id="tabContent">
          <div class="tab-pane fade show active" 
               id="content-1" 
               role="tabpanel" 
               aria-labelledby="1">
            <%= render partial: 'shared/search_bar', locals: { path: one_off_commmit_goal_path } %>
            <div class="card-deck">
              <div data-attributes="<%= one_off_commmit_goal_path %>">
                <%= turbo_frame_tag "one_off_commmit_goal", src: one_off_commmit_goal_path, loading: :lazy do %>
                  Loading...
                <% end %>
              </div>
            </div>
          </div>
          <div class="tab-pane fade" 
               id="content-2" 
               role="tabpanel" 
               aria-labelledby="2">
            <%= render partial: 'shared/search_bar', locals: { path: repeatable_commmit_goal_path } %>
            <div class="card-deck">
              <div data-attributes="<%= repeatable_commmit_goal_path %>">
                <%= turbo_frame_tag "repeatable_commmit_goal", src: repeatable_commmit_goal_path, loading: :lazy do %>
                  Loading...
                <% end %> 
              </div>
            </div>
          </div>
          <div class="tab-pane fade" 
               id="content-3" 
               role="tabpanel" 
               aria-labelledby="3">
            <%= turbo_frame_tag "story_form", class: 'h-100' do %>
              <%= render 'stories/choose_commmit_goal/form', story: Story.new  %>
            <% end %>
          </div>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-dismiss="modal"><%= t('commmits.planned_stories.index.close_modal') %></button>
      </div>
    </div>
  </div>
</div>
<% content_for :hide_footer_nav? do %>
  true
<% end %>

<%= form_for @story, html: { class: "grid-content" } do |f| %>
  <div class="form-group">
    <%= f.label :goal, 'I want...' %>
    <%= f.text_field :goal, required: true, autocomplete: 'off', autocapitalize: "none", placeholder: '...some goal,', class: "form-control", autofocus: :autofocus %>
  </div>

  <div class="form-group">
    <%= f.label :reason, 'so that...' %>
    <%= f.text_field :reason, autocomplete: 'off', autocapitalize: "none", placeholder: '...some reason.', class: "form-control" %>
  </div>

  <div class="form-group">
    <%= f.label :notes %><br/>
    <%= f.text_area :notes, autocomplete: 'off', class: "form-control"  %>
  </div>

  <div class="form-action-buttons">
    <%= f.submit "Create Story", class: "btn btn-lg btn-success btn-block" %>
    <%= link_to 'Cancel', stories_path, class: "btn btn-lg btn-secondary btn-block" %>
  </div>
<% end %>

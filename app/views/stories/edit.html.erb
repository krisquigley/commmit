<div class="grid-content">
  <%= form_with model: @story, html: { class: 'flex-form' } do |f| %>
    <div class="form-content" data-controller="stories">
      <%= render 'fields', f: f, story: @story %>
    </div>

    <div class="form-group form-actions">
      <%= f.submit t('stories.form.update'), class: "btn btn-lg btn-danger btn-block" %>
      <%= link_to t('stories.form.cancel'), stories_path, class: "btn btn-lg btn-secondary btn-block" %>
    </div>
  <% end %>
</div>

<% content_for(:hide_footer_nav?) do %>
  true
<% end %>
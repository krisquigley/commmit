<%= turbo_stream.update "story_form", 
                        partial: 'stories/form', 
                        locals: { story: Story.new } %>

<% if @story.repeatable? %>
  <%= turbo_stream.prepend "repeatable_stories", 
                          partial: 'stories/story', 
                          locals: { story: @story } %>
<% else %>
  <!-- TODO: This isn't going to work for editing stories inline -->
  <%= turbo_stream.prepend "one_off_stories", 
                          partial: 'stories/story', 
                          locals: { story: @story } %>
<% end %>

<%= turbo_stream.prepend "flash", 
                          partial: "shared/flash", 
                          locals: { msg_type: :notice, message: t('stories.notice.created') } %>

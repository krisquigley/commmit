<% if @story.repeatable? %>
  <%= turbo_stream.prepend "repeatable_stories-1", 
                           partial: 'stories/story', 
                           locals: { story: @story } %>
  
  <%= turbo_stream.prepend "add_repeatable_stories-1", 
                           partial: 'planned_stories/add_stories/story', 
                           locals: { story: @story, commmit: @commmit } if @commmit %>
<% else %>
  <%= turbo_stream.prepend "one_off_stories-1", 
                           partial: 'stories/story', 
                           locals: { story: @story }%>
<% end %>

<%= turbo_stream.append "planned_stories", 
                        partial: 'planned_stories/planned_story', 
                        locals: { 
                          planned_story: @story.planned_stories.first, 
                          commmit: @commmit 
                        } if @commmit %>

<%= turbo_stream.replace "story_form", 
                         partial: 'stories/form', 
                         locals: { story: Story.new } %>

<%= turbo_stream.prepend "flash", 
                         partial: "shared/flash", 
                         locals: { msg_type: :notice, message: t('stories.notice.created') } %>
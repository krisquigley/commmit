<%= turbo_stream.update "planned_stories_story_form",
                        partial: 'planned_stories/add_stories/form',
                        locals: { story: Story.new, commmit: @commmit } %>

<% if @story.repeatable? %>
  <%= turbo_stream.prepend "add_repeatable_stories", 
                           partial: 'stories/story', 
                           locals: { story: @story, commmit: @commmit } %>
<% end %>

<%= turbo_stream.append "planned_stories", 
                        partial: 'planned_stories/planned_story', 
                        locals: { 
                          planned_story: @story.planned_stories.first,
                          commmit: @commmit,
                          reflecting: false
                        } %>

<%= turbo_stream.prepend "flash", 
                          partial: "shared/flash", 
                          locals: { msg_type: :notice, message: t('stories.notice.created') } %>
<%= form_with url: commmit_reflection_path(@commmit, @reflection), data: { turbo: false } do |f| %>
  <div class="form-content">
    <div class="form-group mb-5">
      <h6 class="text-center mb-3"><%= t('commmits.reflection.form.goal_met.label') %></h6>
      <p class="text-center">'<%= @commmit.name %>'</p>
      <div class="btn-group btn-group-toggle w-100" data-toggle="buttons" role="group" aria-label="Commmit Goal Met?">
        <label class="btn btn-secondary btn-colored_toggle w-50" for="goal_met_false">
          <%= f.radio_button :goal_met, false %>
          No
        </label>

        <label class="btn btn-secondary btn-colored_toggle w-50" for="goal_met_true">
          <%= f.radio_button :goal_met, true, required: true %>
          Yes
        </label>
      </div>
    </div>

    <div class="form-group mb-5">
      <h6 class="text-center mb-3" data-controller="reflection">
        <%= t('commmits.reflection.form.notes.label') %>
        <svg xmlns="http://www.w3.org/2000/svg" 
             width="16" 
             height="16" 
             fill="currentColor" 
             class="ml-1 bi bi-question-circle" 
             viewBox="0 0 16 16" 
             data-toggle="tooltip" 
             data-placement="top"
             data-html="true"
             title="What went well?<br/>What could be better?<br/>What would you do differently next time?"
             data-action="click->reflection#showReflectionTooltip">
          <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14zm0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16z"/>
          <path d="M5.255 5.786a.237.237 0 0 0 .241.247h.825c.138 0 .248-.113.266-.25.09-.656.54-1.134 1.342-1.134.686 0 1.314.343 1.314 1.168 0 .635-.374.927-.965 1.371-.673.489-1.206 1.06-1.168 1.987l.003.217a.25.25 0 0 0 .25.246h.811a.25.25 0 0 0 .25-.25v-.105c0-.718.273-.927 1.01-1.486.609-.463 1.244-.977 1.244-2.056 0-1.511-1.276-2.241-2.673-2.241-1.267 0-2.655.59-2.75 2.286zm1.557 5.763c0 .533.425.927 1.01.927.609 0 1.028-.394 1.028-.927 0-.552-.42-.94-1.029-.94-.584 0-1.009.388-1.009.94z"/>
        </svg>
      </h6> 

      <%= f.text_area :notes, class: "form-control", rows: 10 , placeholder: t('commmits.reflection.form.notes.placeholder') %>
    </div>

    <h6 class="text-center mb-3"><%= t('commmits.reflection.form.happiness.label') %></h6>
    <div class="reflection__happiness mb-5">
      <%= f.label '1', for: 'happiness_1', class: "form-check-label reflection__happiness_label" do %>
        <%= f.radio_button :happiness, 1, class: "form-check-input reflection__happiness_option", required: true %>
        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="#8d8d8d" class="bi bi-emoji-angry" viewBox="0 0 16 16">
          <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14zm0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16z"/>
          <path d="M4.285 12.433a.5.5 0 0 0 .683-.183A3.498 3.498 0 0 1 8 10.5c1.295 0 2.426.703 3.032 1.75a.5.5 0 0 0 .866-.5A4.498 4.498 0 0 0 8 9.5a4.5 4.5 0 0 0-3.898 2.25.5.5 0 0 0 .183.683zm6.991-8.38a.5.5 0 1 1 .448.894l-1.009.504c.176.27.285.64.285 1.049 0 .828-.448 1.5-1 1.5s-1-.672-1-1.5c0-.247.04-.48.11-.686a.502.502 0 0 1 .166-.761l2-1zm-6.552 0a.5.5 0 0 0-.448.894l1.009.504A1.94 1.94 0 0 0 5 6.5C5 7.328 5.448 8 6 8s1-.672 1-1.5c0-.247-.04-.48-.11-.686a.502.502 0 0 0-.166-.761l-2-1z"/>
        </svg>
        1
      <% end %>
      <hr class="reflection__happiness_rule"/>
      <%= f.label '2', for: 'happiness_2', class: "form-check-label reflection__happiness_label" do %>
        <%= f.radio_button :happiness, 2, class: "form-check-input reflection__happiness_option" %>
        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="#8d8d8d" class="bi bi-emoji-frown" viewBox="0 0 16 16">
          <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14zm0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16z"/>
          <path d="M4.285 12.433a.5.5 0 0 0 .683-.183A3.498 3.498 0 0 1 8 10.5c1.295 0 2.426.703 3.032 1.75a.5.5 0 0 0 .866-.5A4.498 4.498 0 0 0 8 9.5a4.5 4.5 0 0 0-3.898 2.25.5.5 0 0 0 .183.683zM7 6.5C7 7.328 6.552 8 6 8s-1-.672-1-1.5S5.448 5 6 5s1 .672 1 1.5zm4 0c0 .828-.448 1.5-1 1.5s-1-.672-1-1.5S9.448 5 10 5s1 .672 1 1.5z"/>
        </svg>
        2
      <% end %>
      <hr class="reflection__happiness_rule"/>
      <%= f.label '3', for: 'happiness_3', class: "form-check-label reflection__happiness_label" do %>
        <%= f.radio_button :happiness, 3, class: "form-check-input reflection__happiness_option" %>
        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="#8d8d8d" class="bi bi-emoji-neutral" viewBox="0 0 16 16">
          <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14zm0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16z"/>
          <path d="M4 10.5a.5.5 0 0 0 .5.5h7a.5.5 0 0 0 0-1h-7a.5.5 0 0 0-.5.5zm3-4C7 5.672 6.552 5 6 5s-1 .672-1 1.5S5.448 8 6 8s1-.672 1-1.5zm4 0c0-.828-.448-1.5-1-1.5s-1 .672-1 1.5S9.448 8 10 8s1-.672 1-1.5z"/>
        </svg>
        3
      <% end %>
      <hr class="reflection__happiness_rule"/>
      <%= f.label '4', for: 'happiness_4', class: "form-check-label reflection__happiness_label" do %>
        <%= f.radio_button :happiness, 4, class: "form-check-input reflection__happiness_option" %>
        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="#8d8d8d" class="bi bi-emoji-smile" viewBox="0 0 16 16">
          <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14zm0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16z"/>
          <path d="M4.285 9.567a.5.5 0 0 1 .683.183A3.498 3.498 0 0 0 8 11.5a3.498 3.498 0 0 0 3.032-1.75.5.5 0 1 1 .866.5A4.498 4.498 0 0 1 8 12.5a4.498 4.498 0 0 1-3.898-2.25.5.5 0 0 1 .183-.683zM7 6.5C7 7.328 6.552 8 6 8s-1-.672-1-1.5S5.448 5 6 5s1 .672 1 1.5zm4 0c0 .828-.448 1.5-1 1.5s-1-.672-1-1.5S9.448 5 10 5s1 .672 1 1.5z"/>
        </svg>
        4
      <% end %>
      <hr class="reflection__happiness_rule"/>
      <%= f.label '5', for: 'happiness_5', class: "form-check-label reflection__happiness_label" do %>
        <%= f.radio_button :happiness, 5, class: "form-check-input reflection__happiness_option" %>
        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="#8d8d8d" class="bi bi-emoji-sunglasses" viewBox="0 0 16 16">
          <path d="M4.968 9.75a.5.5 0 1 0-.866.5A4.498 4.498 0 0 0 8 12.5a4.5 4.5 0 0 0 3.898-2.25.5.5 0 1 0-.866-.5A3.498 3.498 0 0 1 8 11.5a3.498 3.498 0 0 1-3.032-1.75zM7 5.116V5a1 1 0 0 0-1-1H3.28a1 1 0 0 0-.97 1.243l.311 1.242A2 2 0 0 0 4.561 8H5a2 2 0 0 0 1.994-1.839A2.99 2.99 0 0 1 8 6c.393 0 .74.064 1.006.161A2 2 0 0 0 11 8h.438a2 2 0 0 0 1.94-1.515l.311-1.242A1 1 0 0 0 12.72 4H10a1 1 0 0 0-1 1v.116A4.22 4.22 0 0 0 8 5c-.35 0-.69.04-1 .116z"/>
          <path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0zm-1 0A7 7 0 1 0 1 8a7 7 0 0 0 14 0z"/>
        </svg>
        5
      <% end %>
    </div>
  </div>

  <div class="form-group form-actions">
    <%= f.hidden_field :redirect, value: params[:redirect] %>
    <%= f.submit t('commmits.reflection.form.create'), class: "btn btn-lg btn-success btn-block" %>
    <%= link_to t('commmits.reflection.form.cancel'), commmit_planned_stories_path(@commmit), class: "btn btn-lg btn-secondary btn-block" %>
  </div>
<% end %>
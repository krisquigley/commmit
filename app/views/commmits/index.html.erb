<% content_for :nav_header do %>
  Commmits
<% end %> 

<div class="grid-content">
  <% if @commmits.empty? %>
    <p class="text-center text-secondary mt-2">You haven't created any Commmits yet</p>
  <% end %>

  <div class="card-deck">
    <% @commmits.each do |commmit| %>
      <%# TODO: If this is a one/two day commmit then show a progress bar, if it is more than two days, show a burndown chart %>
      <%= link_to commmit_path(commmit), class: "card" do %>
        <div class="progress">
          <div class="progress-bar" role="progressbar" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100"></div>
        </div>
        <div class="card-body">
          <h6><b><%= commmit.name %></b></h6>
        </div>
        <div class="card-footer">
          <small><i>Started <%= distance_of_time_in_words(commmit.start_date, Date.today, scope: 'datetime.distance_in_words.days_and_months')%>.</i></small>
        </div>
      <% end %>
    <% end %>
  </div>
</div>

<%= render "shared/actions", actions: [{ label: 'New Commmit', path: new_commmit_path }] %>
<%= form_for @commmit do |f| %>
  <div class="form-group">
    <%= f.label :name %>
    <%= f.text_field :name, required: true, placeholder: 'Name or Goal', class: "form-control" %>
  </div>

  <div class="form-group">
    <%= f.label :start_date %><br/>
    <div class="btn-group btn-group-toggle" data-toggle="buttons" style="width: 100%">
      <label class="btn btn-secondary active" style="width: 50%">
        <input type="radio" name="day" id="today" checked> Today
      </label>
      <label class="btn btn-secondary" style="width: 50%">
        <input type="radio" name="day" id="tomorrow"> Tomorrow
      </label>
    </div>
    <%= f.text_field :start_date, required: true, class: "form-control", type: :date, value: Date.today  %>
  </div>

  <div class="form-group">
    <%= f.label :length_in_days, value: 'Length', type: :number, min: 1 %><br/>
    <%= f.select :length_in_days, options_for_select({ "One Day": "1", "Two Days": "2", "Three Days": "3", "Four Days": "4", "Five Days": "5" }, selected: "One Day"), {}, class: "form-control w-100" %> 
  </div>
  <div class="fixed-bottom">
    <%= link_to 'Cancel', commmits_path, class: "btn btn-secondary btn-block" %>
    <%= f.submit "Create Commmit", class: "btn btn-primary btn-block" %>
  </div>
<% end %>


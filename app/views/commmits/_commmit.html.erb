<%# TODO: If this is a one/two day commmit then show a progress bar, if it is more than two days, show a burndown chart %>
<div class="card <%= commmit.finished? ? "card--finished" : "" %>" data-controller="navigate" data-action="click->navigate#navigate">
  <%= render 'shared/progress', commmit: commmit %>

  <div class="card-body">
    <%= button_to commmit_path(commmit), method: :delete, class: 'link-button discard-link', data: { action: "click->navigate#stopPropagation" } do %>
      <%= image_tag asset_pack_path('media/images/close_icon.svg') %> 
    <% end %>
    <h6><b><%= link_to commmit.name, commmit_path(commmit), data: { navigate_target: :link } %></b></h6>
  </div>
  <div class="card-footer">
    <div class="card-footer__left">
      <small><%= commmit.planned_stories.count %></small>
      <%= image_tag asset_pack_path('media/images/story_icon.svg'), class: 'ml-1' %> 
    </div>
    <div class="card-footer__right">
      <%= render 'status', commmit: commmit %>
      <%= image_tag asset_pack_path('media/images/clock_icon.svg'), class: 'ml-1' %>
    </div>
  </div>
</div>

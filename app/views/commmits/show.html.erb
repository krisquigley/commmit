<% content_for :nav_header do %>
  <%= @commmit.name %>
<% end %> 

<div class="grid-content">
  <% if @commmit.stories.empty? %>
    <p class="text-center text-secondary mt-2">You haven't added any stories yet</p>
  <% end %>
  <div class="card-deck">
    <% @commmit.stories.each do |story| %>
      <div class="card" style="<%= story.completed? ? "opacity: 50%" : "" %>">
        <div class="card-body">
          <%= button_to 'Mark as Done', story_mark_as_done_path(story), class: 'btn btn-success', method: :patch %>
          <small><i>I want&hellip;</i></small>
          <h6><b><%= story.i_want %></b></h6>
          <small><i>So that&hellip;</i></small>
          <h6><b><%= story.so_that %></b></h6>
        </div>
      </div>
    <% end %>
  </div>
</div>


<div class="grid-actions">
  <button type="button" class="btn btn-lg btn-primary btn-block" data-toggle="modal" data-target="#addPlanModal">
    Add Stories
  </button>
</div>

<!-- Modal -->
<div class="modal fade" id="addPlanModal" tabindex="-1" aria-labelledby="addPlanModalLabel" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="exampleModalLabel">Add Stories</h5>
        <button type="button" class="close" data-dismiss="modal" aria-label="Close">
          <span aria-hidden="true">&times;</span>
        </button>
      </div>
      <div class="modal-body">
        <div class="card-deck">
          <% if @stories.empty? %>
            <p class="text-center text-secondary mt-2">
              You haven't <%= link_to 'created any stories', new_story_path %> yet.
            </p>
          <% end %>
          <% @stories.each do |story| %>
            <div class="card">
              <div class="card-body">
                <%= form_for story do |f| %>
                  <%= f.hidden_field :commmit_id, value: @commmit.id %>
                  <%= f.submit 'Add to Commmit', class: 'btn btn-success' %>
                <% end %>
                <small><i>I want&hellip;</i></small>
                <h5><b><%= story.i_want %></b></h5>
                <small><i>So that&hellip;</i></small>
                <h6><b><%= story.so_that %></b></h6>
              </div>
            </div>
          <% end %>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-dismiss="modal">Done</button>
      </div>
    </div>
  </div>
</div>
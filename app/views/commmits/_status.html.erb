<% if commmit.finished? %>
  <small>
    <i>
      <%= t('commmits.index.statuses.finished') %> 
      <%= distance_of_time_in_words(commmit.end_date, 
                                    Time.current.to_date, 
                                    scope: 'datetime.distance_in_words.days_and_months')
      %>
    </i>
  </small>
<% else %>
  <small>
    <i>
      <%= t('commmits.index.statuses.in_progress') %> 
      <%= distance_of_time_in_words(commmit.end_date, 
                                    Time.current.to_date, 
                                    scope: 'datetime.distance_in_words.days_and_months_future')
      %>
    </i>
  </small>
<% end %>
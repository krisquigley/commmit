<div class="grid-content">
  <%= form_with model: @value, html: { class: 'flex-form' } do |f| %>
    <div class="form-content">
      <%= render 'fields', f: f %>
    </div>

    <div class="form-group form-actions">
      <%= f.submit t('values.form.update'), class: "btn btn-lg btn-success btn-block" %>
      <%= link_to t('values.form.cancel'), values_path, class: "btn btn-lg btn-secondary btn-block" %>
    </div>
  <% end %>
</div>

<% content_for(:hide_footer_nav?) do %>
  true
<% end %>
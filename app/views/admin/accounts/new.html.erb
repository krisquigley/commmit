<%= form_for [:admin, @account] do |f| %>
  <div class="row mt-4 mb-4">
    <div class="col-sm-9">
      <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
          <li class="breadcrumb-item"><%= link_to "Accounts", admin_root_path %></li>
          <li class="breadcrumb-item active" aria-current="page">Add Account</li>
        </ol>
      </nav>
    </div>
    <div class="col-sm-3">
      <%= f.submit 'Save', class: 'btn btn-success btn-block btn-lg'%>
    </div>
  </div>
  <%= render "form", f: f %>
<% end %>

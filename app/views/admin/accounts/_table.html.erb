<div class="table-responsive">
  <table class="table table-hover">
    <thead class="thead-light">
      <tr>
        <th>Account Name</th>
        <th>Subdomain</th>
      </tr>
    </thead>
    <tbody>
      <% accounts.each do |account| %>
        <tr>
          <td><%= account.name %></td>
          <td><%= account.subdomain %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
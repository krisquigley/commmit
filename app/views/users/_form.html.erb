<%= form_for @user do |f| %>
  <div class="form-group">
    <%= f.label :name %>
    <%= f.text_field :name, required: true, class: "form-control" %>
  </div>
  <div class="form-group">
    <%= f.label :team %>
    <%= f.collection_select(:team_id, Team.all, :id, :name, {prompt: true}, {class: "form-control"}) %>
  </div>
  <%= f.submit class: "btn btn-success" %>
<% end %>
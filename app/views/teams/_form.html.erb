<%= form_for @team do |f| %>
  <div class="row mt-4">
    <div class="col-sm-10">
      <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
          <li class="breadcrumb-item"><%= link_to "Home", root_path %></li>
          <li class="breadcrumb-item"><%= link_to "Teams", teams_path %></li>
          <li class="breadcrumb-item active" aria-current="page"><%= !@team.id ? "New Team" : "Edit Team" %></li>
        </ol>
      </nav>
    </div>
    <div class="col-sm-2">
      <%= f.submit class: "btn btn-success btn-lg btn-block" %>
    </div>
  </div>
  
  <%= render 'shared/errors', object: @team %>

  <div class="form-group mt-4">
    <%= f.label :name %>
    <%= f.text_field :name, required: true, class: "form-control" %>
  </div>
  <div class="form-group">
    <%= f.label :users %>
    <table class="table">
      <tbody>
      <% User.order('LOWER(name)').each do |user| %>
        <tr>
          <td>
            <div class="form-check">
              <%= f.check_box :user_ids, { multiple: true, class: "form-check-input" }, user.id, false %>
              <%= f.label "user_ids_#{user.id}", user.name, class: "form-check-label" %>
            </div>
          </td>
        </tr>
      <% end %>
      </tbody>
    </table>
  </div>
  
<% end %>
<div class="row mt-4">
  <div class="col-sm-10">
    <nav aria-label="breadcrumb">
      <ol class="breadcrumb">
        <li class="breadcrumb-item"><%= link_to "Home", root_path %></li>
        <li class="breadcrumb-item active" aria-current="page">Teams</li>
      </ol>
    </nav>
  </div>
  <div class="col-sm-2 text-right">
    <%= link_to 'New Team', new_team_path, class: 'btn btn-success btn-lg btn-block' %>
  </div>
</div>
<table class="table table-hover mt-4">
  <thead class="thead-light">
    <tr>
      <th>Name</th>
      <th>Devs</th>
      <th>Edit</th>
    </tr>
  </thead>
  <tbody>
    <% @teams.each do |team| %>
      <tr>
        <td><%= link_to team.name, team_path(team) %></td>
        <td><%= team.users ? team.users.count : 0 %></td>
        <td><%= link_to 'Edit', edit_team_path(team), class: 'btn btn-warning' %></td>
      </tr>
    <% end %>
  </tbody>
</table>


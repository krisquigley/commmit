<h1>Teams</h1>
<%= link_to 'New Team', new_team_path, class: 'btn btn-success' %>
<table class="table table-hover">
  <thead>
    <tr>
      <th>Name</th>
      <th>Devs</th>
    </tr>
  </thead>
  <tbody>
    <% @teams.each do |team| %>
      <tr>
        <td><%= link_to team.name, team_path(team) %></td>
        <td><%= team.users ? team.users.count : 0 %></td>
      </tr>
    <% end %>
  </tbody>
</table>


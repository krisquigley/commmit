<div class="table-responsive">
  <table class="table table-hover">
    <thead class="thead-primary">
      <tr>
        <th>Team Name</th>
      </tr>
    </thead>
    <tbody>
      <% teams.each do |team| %>
        <tr>
          <td><%= link_to team.name, team_path(team) %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
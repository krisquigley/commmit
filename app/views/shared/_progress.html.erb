<div class="progress">
  <div class="progress-bar" role="progressbar" data-planned-stories-target="progressBarLeft"
      aria-valuenow="<%= total_count - completed_count %>" 
      style="width: <%= percentage_left(total_count, completed_count) || 0 %>%"
      aria-valuemin="0" aria-valuemax="<%= total_count %>">
      <%= total_count - completed_count %>
  </div>
  <div class="progress-bar bg-success" role="progressbar" data-planned-stories-target="progressBarDone"
      aria-valuenow="<%= completed_count %>" 
      style="width: <%= percentage_done(total_count, completed_count) || 0 %>%"
      aria-valuemin="0" aria-valuemax="<%= total_count %>">
    <%= completed_count %>
  </div>
</div>
<% content_for :nav_header do %>
  <%= @commmit.name %>
<% end %> 

<div class="grid-topcontent">
  <%= render 'shared/progress', total_count: (@planned_stories.size + @completed_stories.size), completed_count: @completed_stories.size %>
</div>

<div class="grid-content">
  <% if !@commmit.in_progress? %>
    <p class="text-center text-secondary mt-2"><%= t('commmits.planned_stories.index.finished') %></p>
  <% end %>
  
  <div class="card-deck" data-container="planned_stories">
    <p class="text-center text-secondary mt-2" data-planned-stories-target="message"></p>

    <%= turbo_frame_tag "planned_stories", data: { 'planned-stories_target': 'plannedStories'} do %>
      <%= render partial: 'planned_story', 
                collection: @planned_stories, 
                locals: { commmit: @commmit } %>
    <% end %>

    <%= content_tag :div, class: 'divider', data: { 'planned-stories_target': 'doneDivider' } do %>
      <div class="dropdown-divider"></div>

      <small><%= t('commmits.planned_stories.index.done_divider') %></small>
      
      <div class="dropdown-divider"></div>
    <% end %>

    <%= turbo_frame_tag "completed_planned_stories", data: { 'planned-stories_target': 'completedStories'} do %>
      <%= render partial: 'planned_story', 
                collection: @completed_stories, 
                locals: { commmit: @commmit } %>
    <% end %>

    <div class="page-actions">
      <%= link_to new_commmit_path, class: "btn btn-lg btn-primary btn-block" do %>
        <%= t('commmits.index.new_commmit') %> 
      <% end if !Commmit.active_commmits? %>

      <%= button_tag class: "btn btn-lg btn-#{@commmit.in_progress? ? 'primary' : 'secondary' } btn-block", disabled: @commmit.reflected?, data: { toggle: "modal", target: "#addStoriesModal" } do %>
        <%= @commmit.reflected? ? t('commmits.planned_stories.index.finished') : t('commmits.planned_stories.index.add_stories') %> 
      <% end %>
    </div>
  </div>
</div>

<%= render 'planned_stories/add_stories/modal', one_off_stories_page: @one_off_stories_page, repeatable_stories_page: @repeatable_stories_page, story: @story, commmit: @commmit %>
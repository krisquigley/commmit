<div class="modal fade" id="addStoriesModal" tabindex="-1" aria-labelledby="addPlanModalLabel" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
    
      <%= render 'planned_stories/add_stories/modal_header' %>

      <div class="modal-body">
        <div class="tab-content modal-tab-content" id="storiesTabContent">
          <div class="tab-pane fade show active" 
               id="<%= t('stories.form.repeatable.once') %>" 
               role="tabpanel" 
               aria-labelledby="<%= t('stories.form.repeatable.once') %>-tab">
            <div class="card-deck">
              <%= turbo_frame_tag "add_one_off_stories", src: commmit_add_one_off_stories_path, loading: :lazy do %>
                Loading...
              <% end %>
            </div>
          </div>
          <div class="tab-pane fade" 
               id="<%= t('stories.form.repeatable.forever').gsub(' ', '-') %>" 
               role="tabpanel" 
               aria-labelledby="<%= t('stories.form.repeatable.forever').gsub(' ', '-') %>-tab">
            <div class="card-deck">
              <%= turbo_frame_tag "add_repeatable_stories", src: commmit_add_repeatable_stories_path, loading: :lazy do %>
                Loading...
              <% end %> 
            </div>
          </div>
          <div class="tab-pane fade" 
               id="<%= t('stories.index.new_story').gsub(' ', '-') %>" 
               role="tabpanel" 
               aria-labelledby="<%= t('stories.index.new_story').gsub(' ', '-') %>-tab">
            <%= turbo_frame_tag "planned_stories_story_form", class: 'h-100' do %>
              <%= render 'planned_stories/add_stories/form', story: Story.new, commmit: commmit %>
            <% end %>
          </div>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-dismiss="modal"><%= t('commmits.planned_stories.index.close_modal') %></button>
      </div>
    </div>
  </div>
</div>
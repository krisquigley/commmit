<div class="modal fade" id="addStoriesModal" tabindex="-1" aria-labelledby="addPlanModalLabel" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content" data-controller="swipe-between-tabs">
    
      <%= render 'planned_stories/add_stories/modal_header' %>

      <div class="modal-body">
        <div class="tab-content modal-tab-content" id="tabContent">
          <div class="tab-pane fade show active" 
               id="content-1" 
               role="tabpanel" 
               aria-labelledby="1">
            <%= render partial: 'shared/search_bar', locals: { path: commmit_add_one_off_stories_path(commmit) } %>
            <div class="card-deck">
              <div data-attributes="<%= commmit_add_one_off_stories_path(commmit) %>">
                <%= turbo_frame_tag "add_one_off_stories", src: commmit_add_one_off_stories_path, loading: :lazy do %>
                  Loading...
                <% end %>
              </div>
            </div>
          </div>
          <div class="tab-pane fade" 
               id="content-2" 
               role="tabpanel" 
               aria-labelledby="2">
            <%= render partial: 'shared/search_bar', locals: { path: commmit_add_repeatable_stories_path(commmit) } %>
            <div class="card-deck">
              <div data-attributes="<%= commmit_add_repeatable_stories_path(commmit) %>">
                <%= turbo_frame_tag "add_repeatable_stories", src: commmit_add_repeatable_stories_path, loading: :lazy do %>
                  Loading...
                <% end %> 
              </div>
            </div>
          </div>
          <div class="tab-pane fade" 
               id="content-3" 
               role="tabpanel" 
               aria-labelledby="3">
            <%= turbo_frame_tag "planned_stories_story_form", class: 'h-100' do %>
              <%= render 'planned_stories/add_stories/form', story: Story.new, commmit: commmit %>
            <% end %>
          </div>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-dismiss="modal"><%= t('commmits.planned_stories.index.close_modal') %></button>
      </div>
    </div>
  </div>
</div>
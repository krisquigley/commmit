<% content_for :nav_header do %>
  <%= t('stories.form.tags.label_html') %>
<% end %> 

<div class="grid-topcontent">
  <%= render 'create_tag', story: @story %>
</div>
<div class="grid-content">
  <%= form_with model: @story, html: { class: 'flex-form' } do |f| %>
    <div class="form-content">
      <div class="form-group">
        <%= label_tag t('tags.show.header') %>
      </div>
      <%= f.collection_check_boxes(:tag_ids, @tags, :id, :name, include_hidden: false) do |b| %>
        <div class="form-check form-check-inline">
          <%= b.check_box class: 'form-check-input', checked: @story.tags.any? { |t| t.id == b.value } %>
          <%= b.label class: 'form-check-label' %>
        </div>
      <% end %>
    </div>
    <div class="form-group form-actions">
      <%= f.submit t('tags.form.update'), class: 'btn btn-success btn-lg btn-block' %>
    </div>
  <% end %>
</div>

<% content_for :hide_footer_nav? do %>
  true
<% end %>

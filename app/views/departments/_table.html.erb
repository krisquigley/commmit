<div class="table-responsive">
  <table class="table table-hover">
    <thead class="thead-light">
      <tr>
        <th>Name</th>
      </tr>
    </thead>
    <tbody>
      <% object.each do |department| %>
        <tr>
          <td><%= link_to department.name, department_path(department) %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>